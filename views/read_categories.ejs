<!-- include header -->
<%- include('include/_headerAdmin') %>
<!-- /include header -->


<main>

  <table class="table">
    <thead>
      <tr>
        <th scope="col">#</th>
        <th scope="col">Nombre</th>
        <th scope="col">Editar</th>
        <th scope="col">Eliminar</th>
      </tr>
    </thead>
    <tbody>
      <% categories.forEach(function(category) { %>
      <tr>
        <th scope="row"><%= category._id %></th>
        <td><%= category.nombre %></td>

        <td>
          <a href="/update-category?id=<%= category._id %>" class="btn btn-success">Editar</a>
        </td>

        <td>
          <a href="/api/categories/<%= category._id %>" class="btn btn-danger delete">Eliminar</a>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>

</main>



<!-- include footer -->
<%- include('include/_footerAdmin') %>
<!-- /include footer -->