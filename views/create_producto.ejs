<%- include('include/_headerAdmin') %>

<h1>Crear Nuevo Producto</h1>
<div class="container mt-4">
    <form action="/api/productos" method="POST" enctype="multipart/form-data">
        <!-- Nombre -->
        <div class="form-group">
        <label for="nombre">Nombre del producto</label>
        <input type="text" class="form-control" id="nombre" name="nombre" required>
        </div>

        <!-- Precio de costo -->
        <div class="form-group">
        <label for="precioCosto">Precio de costo (Inversión)</label>
        <input type="number" step="0.01" class="form-control" id="precioCosto" name="precioCosto" required>
        </div>

        <!-- Precio venta -->
        <div class="form-group">
        <label for="precio">Precio de venta</label>
        <input type="number" step="0.01" class="form-control" id="precio" name="precio" required>
        </div>

        <!-- Stock -->
        <div class="form-group">
        <label for="stock">Stock</label>
        <input type="number" class="form-control" id="stock" name="stock" required>
        </div>

        <!-- Categoría -->
        <div class="form-group">
        <label for="categoria">Categoría</label>
        <select class="form-control" id="categoria" name="categoria" required>
            <option value="">Seleccione una categoría</option>
            <% categorias.forEach(c => { %>
            <option value="<%= c._id %>"><%= c.nombre %></option>
            <% }) %>
        </select>
        </div>

        <!-- Marca -->
        <div class="form-group">
        <label for="marca">Marca</label>
        <select class="form-control" id="marca" name="marca" required>
            <option value="">Seleccione una marca</option>
            <% marcas.forEach(m => { %>
            <option value="<%= m._id %>"><%= m.nombre %></option>
            <% }) %>
        </select>
        </div>

        <!-- Proveedor (opcional) -->
        <div class="form-group">
        <label for="proveedor">Proveedor</label>
        <select class="form-control" id="proveedor" name="proveedor">
            <option value="">Seleccione un proveedor</option>
            <% proveedores.forEach(p => { %>
            <option value="<%= p._id %>"><%= p.nombre %></option>
            <% }) %>
        </select>
        </div>

        <!-- Imagen -->
        <div class="form-group">
        <label for="foto">Imagen</label>
        <input type="file" class="form-control" id="foto" name="foto">
        </div>

        <button type="submit" class="btn btn-primary mt-3">Crear Producto</button>
    </form>
    </div>

<%- include('include/_footerAdmin') %>