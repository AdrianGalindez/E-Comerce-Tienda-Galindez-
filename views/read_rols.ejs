<!-- include header -->
<%- include('include/_headerAdmin') %>
<!-- /include header -->




<main>

  <table class="table">
    <thead>
      <tr>
        <th scope="col">#</th>
        <th scope="col">Nombre</th>
        <th scope="col">Descripción</th>
        <th scope="col">Editar</th>
        <th scope="col">Eliminar</th>
      </tr>
    </thead>
    <tbody>
      <% roles.forEach(function(rol) { %>
      <tr>
        <th scope="row"><%= rol._id %></th>
        <td><%= rol.nombre %></td>
        <td><%= rol.descripcion %></td>

        <td>
          <a href="/update-rol?id=<%= rol._id %>" class="btn btn-success">Editar</a>
        </td>

        <td>
          <a href="/api/roles/<%= rol._id %>" class="btn btn-danger delete">Eliminar</a>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>

</main>

<!-- include footer -->
<%- include('include/_footerAdmin') %>
<!-- /include footer -->





